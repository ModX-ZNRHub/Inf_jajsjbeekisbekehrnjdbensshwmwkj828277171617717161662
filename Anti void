local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local player = Players.LocalPlayer

local SETTINGS = {
    TargetY = -50000,
    FloorSize = Vector3.new(200, 1, 200),
    IsActive = false,
    NeonColor = Color3.fromRGB(0, 255, 255)
}

local phantomFloor = nil
workspace.FallenPartsDestroyHeight = -math.huge

local function getPhantomFloor()
    if not phantomFloor or not phantomFloor.Parent then
        phantomFloor = Instance.new("Part")
        phantomFloor.Name = "ModX_VoidBase"
        phantomFloor.Size = SETTINGS.FloorSize
        phantomFloor.Transparency = 1 
        phantomFloor.Anchored = true
        phantomFloor.CanCollide = true
        phantomFloor.Parent = workspace
    end
    return phantomFloor
end

RunService.Heartbeat:Connect(function()
    if not SETTINGS.IsActive then return end
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    
    if hrp and hum then
        local currentCF = hrp.CFrame
        hrp.CFrame = CFrame.new(currentCF.X, SETTINGS.TargetY + 3.5, currentCF.Z) * (currentCF - currentCF.Position)

        hrp.AssemblyLinearVelocity = Vector3.new(
            hrp.AssemblyLinearVelocity.X,
            0,
            hrp.AssemblyLinearVelocity.Z
        )
        
        local floor = getPhantomFloor()
        floor.CFrame = CFrame.new(hrp.Position.X, SETTINGS.TargetY, hrp.Position.Z)
        
        if hum.Health < 100 then hum.Health = 100 end
    end
end)

